# PostgreSQL database credentials
# These are used by Docker Compose and the backend service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ecommerce

# Full database URL used directly by the backend (auto-constructed by Docker Compose)
# DATABASE_URL=postgresql://postgres:changeme@db:5432/ecommerce

# Frontend API URL (set this to your deployed backend URL when deploying to Vercel/Netlify)
# VITE_API_URL=https://your-backend.onrender.com/api
